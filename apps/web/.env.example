# Copy this file to .env and fill in values

# API URL (NestJS backend)
API_URL=http://localhost:4444

# Session
SESSION_SECRET=change-me-to-a-random-64-char-string

# File Storage (S3-compatible)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

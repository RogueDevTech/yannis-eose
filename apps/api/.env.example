# ============================================
# Yannis EOSE — API Environment Variables
# ============================================
# Copy this file to .env and fill in values

# Server
PORT=4444
NODE_ENV=development
CORS_ORIGIN=http://localhost:4000

# Database (Postgres 18)
DATABASE_URL=postgresql://user:password@host:5432/yannis-eose

# Redis
REDIS_URL=redis://user:password@host:6379

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@example.com
SENDGRID_FROM_NAME=Yannis EOSE

# Session
SESSION_SECRET=change-me-to-a-random-64-char-string
SESSION_TTL_SECONDS=86400

# VOIP (Twilio) — Feature flag controlled via Settings > VOIP toggle
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
VOIP_WEBHOOK_BASE_URL=https://your-api-domain.com

# File Storage (Cloudflare R2 / AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=

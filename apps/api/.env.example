# ============================================
# Yannis EOSE — API Environment Variables
# ============================================

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (Postgres 18)
DATABASE_URL=postgresql://user:password@host:5432/yannis_eose

# Redis
REDIS_URL=redis://user:password@host:6379

# Session
SESSION_SECRET=change-me-to-a-random-64-char-string
SESSION_TTL_SECONDS=86400

# VOIP (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# File Storage (Cloudflare R2 / AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=

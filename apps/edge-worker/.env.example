# ============================================
# Yannis EOSE — Edge Worker Environment
# ============================================
# These vars are set in wrangler.toml for local dev
# and via wrangler secret for production

# NestJS API endpoint
API_URL=http://localhost:4444

# QStash (Upstash) — for order buffering failover
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=

# API key for securing internal endpoints (inventory/update)
EDGE_API_KEY=

# Cloudflare Turnstile CAPTCHA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# KV Namespace IDs (created via wrangler kv:namespace create)
# DEDUP_CACHE — stores phone+product dedup hashes (6hr TTL)
# RATE_LIMIT_CACHE — stores per-IP submission counts (5min TTL)
# INVENTORY_CACHE — stores per-product stock levels (5min TTL)
# CAMPAIGN_CACHE — stores campaign configs (10min TTL)

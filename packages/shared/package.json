{
  "name": "@yannis/shared",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./validators": "./src/validators/index.ts",
    "./enums": "./src/enums/index.ts",
    "./trpc": "./src/trpc/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts --",
    "db:seed:heavy": "tsx src/db/seed.ts -- --heavy",
    "db:seed-permissions": "tsx scripts/seed-permissions.ts",
    "db:baseline": "tsx scripts/baseline-migrations.ts",
    "simulate:orders": "tsx test-script/order-simulate.ts",
    "simulate:cs": "tsx test-script/cs-simulation.ts",
    "simulate:logistics": "tsx test-script/logistics-simulation.ts",
    "simulate:3pl": "tsx test-script/3pl-simulation.ts",
    "simulate:all": "tsx test-script/order-simulate.ts && tsx test-script/cs-simulation.ts && tsx test-script/logistics-simulation.ts && tsx test-script/3pl-simulation.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/bcrypt": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@yannis/config": "workspace:*",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}

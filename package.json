{
  "name": "yannis-eose",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "db:seed-permissions": "pnpm --filter @yannis/shared run db:seed-permissions",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",

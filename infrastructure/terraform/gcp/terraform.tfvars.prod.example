# Production tfvars — Yannis EOSE prod on GCP.
#
# Hostnames (Cloudflare-fronted):
#   web    → office.hqyannis.com
#   api    → api-office.hqyannis.com
#   form   → form.hqyannis.com  (Cloudflare Worker — see apps/edge-worker)
#   bucket → backed by GCS, served from storage.googleapis.com or fronted by
#            cdn.hqyannis.com once Phase 21 CDN is wired
#
# Apply against a separate state file from dev so the dev apply can never
# touch prod resources. See README "Production apply" section for the
# `-state` + `-var-file` flags.

project_id          = "REPLACE-WITH-PROD-GCP-PROJECT-ID"
region              = "europe-west2"
zone                = "europe-west2-a"
environment         = "prod"
# A larger machine for prod — e2-small is dev-only. Prod runs web + api +
# nginx + Docker on one box, so it needs real RAM. e2-standard-4 = 4 vCPU /
# 16 GB; e2-standard-2 (2 vCPU / 8 GB) is the floor.
machine_type        = "e2-standard-4"
# Prod VM cannot be deleted until this is flipped back to false.
vm_deletion_protection = true
vm_admin_user       = "deployer"
ssh_public_key      = "ssh-ed25519 AAAA... REPLACE WITH PROD SSH KEY"

public_web_hostname = "office.hqyannis.com"
public_api_hostname = "api-office.hqyannis.com"

# CORS for the public asset bucket — must include every origin that uploads
# directly via signed URL. Today the only such origin is the web app.
bucket_cors_origins = [
  "https://office.hqyannis.com",
]

# Lock SSH to known operator IPs in prod — `0.0.0.0/0` is fine for dev but
# unacceptable for prod. Replace with your office NAT / VPN egress.
ssh_source_ranges   = [
  "REPLACE-WITH-OPERATOR-IP/32",
]

# Web ingress (80/443) must stay open to the world — Cloudflare-proxied
# requests + Let's Encrypt HTTP-01 challenges both originate from changing
# IP ranges. Lock down via Cloudflare WAF, not VPC firewall.
# web_source_ranges = ["0.0.0.0/0"]

# Reverse proxy + TLS are provisioned by Ansible after Terraform apply.
# See `infrastructure/ansible/README.md` for the two-stage flow.

# ──────────────────────────────────────────────────────────────────────────────
# Cloud SQL (Postgres) — minimal-cost prod sizing.
#
# Sized to match the actual measured workload of `yannis-eose-prod` (~1.24 vCPU
# continuous on Regional, ~5 GB RAM, <2 GB stored data) after dropping the
# Regional HA standby. db-g1-small is shared-core: GCP can throttle the CPU
# under noisy-neighbour contention. The Redis read-through cache (CLAUDE.md
# Pillar 1) absorbs most reads, so the DB rarely needs sustained CPU.
#
# Budget: ~$25/mo at the default tier. If CS closers report query lag during
# peak hours, bump `cloud_sql_tier` to `db-custom-1-3840` (~$52/mo, 1 dedicated
# vCPU + 3.75 GB RAM) — one-line change + 5-min restart, no schema work.
#
# IMPORTANT: enabling this creates a NEW empty instance. The app keeps using
# whatever DATABASE_URL is currently in the runtime env secret (still points
# at the legacy `yannis-eose-prod` instance). Migration is a manual
# `pg_dump | pg_restore` followed by a secret rotation — see the "Cloud SQL
# migration" section in the README.
# ──────────────────────────────────────────────────────────────────────────────
enable_cloud_sql              = true
cloud_sql_tier                = "db-g1-small"
cloud_sql_availability        = "ZONAL"
cloud_sql_postgres_version    = "POSTGRES_18"
cloud_sql_disk_size_gb        = 10
cloud_sql_disk_max_size_gb    = 20
cloud_sql_pitr_enabled        = false
cloud_sql_deletion_protection = true

# Backups: Cloud SQL takes free daily automated backups (7-day retention) on
# every instance. For weekly off-instance copies into a GCS bucket, plus an
# (optional) Drive mirror, follow Option B in the README under "Cloud SQL
# migration" — not codified in this tfvars yet so you can flip it on after
# the migration is done.

# Operator IPs that need direct psql access (DBAs, ad-hoc analytics). Stays
# empty by default — you add CIDRs ad-hoc in the GCP console when you need
# them, then drop them again. The VM IP is added automatically.
# cloud_sql_authorized_cidrs = [
#   "REPLACE-WITH-OPERATOR-IP/32",
# ]

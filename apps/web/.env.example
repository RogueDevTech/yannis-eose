# ============================================
# Yannis EOSE — Web Frontend Environment
# ============================================
# Copy this file to .env and fill in values

# API URL (NestJS backend)
API_URL=http://localhost:4444

# Edge Worker — URL of the deployed Cloudflare Worker (apps/edge-worker, wrangler name: yannis-edge-worker)
# Format: https://yannis-edge-worker.<your-cf-subdomain>.workers.dev
# Find your subdomain at: https://dash.cloudflare.com → Workers & Pages
# For local dev with wrangler: http://localhost:8787
EDGE_WORKER_URL=http://localhost:8787

# Session
SESSION_SECRET=change-me-to-a-random-64-char-string

# File Storage (S3-compatible)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

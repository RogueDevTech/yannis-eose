# Production tfvars — Yannis EOSE prod on GCP.
#
# Applied against a SEPARATE state file from dev so the dev apply can never
# touch prod resources. See README "Production apply" section for the
# `-state` + `-var-file` flags.
#
# NOTE: this account currently has a single GCP project, so prod reuses it.
# All prod resources are `prod-yannis-eose-*` and never collide with the
# dev-prefixed resources already in the same project. Move prod to its own
# GCP project before the legacy "Sniper" cutover when the user opens one.

project_id          = "project-26c432ec-b4f1-4e21-a6a"
region              = "europe-west2"
zone                = "europe-west2-a"
environment         = "prod"

# Prod runs web (Remix SSR) + api (NestJS) + nginx + Docker on one VM, so it
# needs real RAM — e2-small (2 GB) is dev-only sizing and starves under load.
# e2-standard-4 = 4 vCPU / 16 GB, with headroom for on-box build/deploy.
# Changing this triggers a brief stop → resize → start on the next apply
# (allow_stopping_for_update is set on the VM resource).
machine_type        = "e2-standard-4"
# Boot disk left at 20 GB — grow it live via `gcloud compute disks resize`
# rather than Terraform (a boot-disk size change can force VM replacement).
vm_boot_disk_size_gb = 20
# Prod VM cannot be deleted until this is flipped back to false.
vm_deletion_protection = true
vm_admin_user       = "deployer"

# Operator SSH key (matches the key on the dev box). Replace with a
# prod-only operator key once one is minted.
ssh_public_key      = "ssh-rsa  Apple@MacBook-Pro-2.local"

public_web_hostname = "office.hqyannis.com"
public_api_hostname = "api-office.hqyannis.com"

# CORS for the public asset bucket — must include every origin that uploads
# directly via signed URL.
bucket_cors_origins = [
  "https://office.hqyannis.com",
]

	# SSH open during initial provisioning so the GitHub Actions runner can land
# the deploy. Lock to operator NAT / VPN egress IPs after first deploy:
#   ssh_source_ranges = ["YOUR_OPERATOR_IP/32"]
ssh_source_ranges   = [
  "0.0.0.0/0",
]

# Web ingress (80/443) must stay open — Cloudflare-proxied requests and
# Let's Encrypt HTTP-01 challenges originate from changing IP ranges. Lock
# down via Cloudflare WAF rules, not VPC firewall.
# web_source_ranges = ["0.0.0.0/0"]

# Reverse proxy + TLS are provisioned by Ansible after Terraform apply.
# See `infrastructure/ansible/README.md` for the two-stage flow.
